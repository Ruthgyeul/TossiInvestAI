{
  "name": "bin-discord-bot",
  "version": "0.1.0",
  "description": "빈(Bin) 트레이딩 봇 — Discord 인터페이스",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "ts-node --esm src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^24.13.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1"
  },
  "overrides": {
    "undici": "^6.27.0"
  }
}
