# ============================================================
# TossiInvestAI (빈/Bin) — 환경변수 템플릿
# 실제 값은 .env 에만 작성한다. .env는 절대 git에 커밋하지 않는다.
# ============================================================

# --- 토스증권 Open API (docs/TOSS_API.md) ---
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
TOSS_ACCOUNT_SEQ=
TOSS_BASE_URL=https://openapi.tossinvest.com

# --- AI Gateway (docs/BIN.md) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=512
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# --- DB (docs/ARCHITECTURE.md) ---
DATABASE_URL=postgresql+asyncpg://bin:changeme@localhost:5432/bin_trading
REDIS_URL=redis://localhost:6379/0

# --- 자금 관리 (docs/FUND_MANAGER.md) ---
INITIAL_SEED_KRW=500000
CASH_BUFFER_RATIO=0.15

# --- Safety Gate (docs/SAFETY.md) ---
MAX_DAILY_LOSS_KRW=50000
MAX_POSITION_RATIO=0.50
MAX_SINGLE_ORDER_KRW=100000
EMERGENCY_STOP=false
KR_STOP=false
US_STOP=false

# --- 운영 모드 (docs/SAFETY.md) ---
DRY_RUN=true
SIMULATION=true
LOG_LEVEL=INFO

# --- Discord (docs/DISCORD.md) ---
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_STATUS_CHANNEL_ID=
DISCORD_ANALYZE_CHANNEL_ID=
DISCORD_BUY_CHANNEL_ID=
DISCORD_SELL_CHANNEL_ID=
DISCORD_SYSTEM_CHANNEL_ID=
DISCORD_ERROR_CHANNEL_ID=
DISCORD_NEWS_CHANNEL_ID=
DISCORD_LOG_CHANNEL_ID=

# --- 트레이딩 코어 내부 API (discord-bot <-> core 통신) ---
CORE_INTERNAL_API_URL=http://localhost:8000
CORE_INTERNAL_API_TOKEN=
