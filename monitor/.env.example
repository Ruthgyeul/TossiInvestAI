# ============================================================
# monitor (BIN MONITOR 키오스크) — 환경변수 템플릿
# 실제 값은 .env 에만 작성한다. .env는 절대 git에 커밋하지 않는다.
# Next.js는 이 파일이 있는 monitor/ 디렉토리 기준으로 .env를 읽는다 — 루트 .env와는 별개다.
# ============================================================

# --- Redis (외부 접속 인증 코드·시도 횟수·차단 상태 저장) ---
# core·discord-bot과 동일한 Redis 인스턴스를 가리킨다 (docs/ARCHITECTURE.md).
REDIS_URL=redis://localhost:6379/0

# --- core 내부 API (GET /api/v1/monitor/snapshot, docs/INTERNAL_API.md) ---
# core는 127.0.0.1에만 바인딩하므로 같은 호스트(라즈베리파이)에서만 접근 가능하다.
CORE_INTERNAL_API_URL=http://localhost:8000
# core의 CORE_INTERNAL_API_TOKEN과 동일한 값. Route Handler(서버 사이드)에서만
# 쓰이고 브라우저로는 절대 내려가지 않는다 (monitor/CLAUDE.md 절대 규칙 3).
CORE_INTERNAL_API_TOKEN=
# true로 설정하면 core를 호출하지 않고 src/lib/mock-snapshot.ts의 목업을 반환한다.
# core 없이 화면/디자인만 확인할 때만 켠다 — 기본은 꺼짐(실데이터).
MONITOR_USE_MOCK_DATA=false

# --- 외부 접속 인증 (docs/MONITOR.md "외부 접속 인증") ---
# 세션 쿠키 서명용 비밀키. `openssl rand -base64 32`로 생성한다.
MONITOR_SESSION_SECRET=
# 인증 통과 후 세션 유지 시간(초). 기본 43200 = 12시간.
MONITOR_SESSION_TTL_SECONDS=43200
# 인증 코드 유효 시간(초). 기본 300 = 5분.
MONITOR_AUTH_CODE_TTL_SECONDS=300
# 코드 재요청 최소 간격(초) — Discord DM 스팸 방지.
MONITOR_AUTH_CODE_COOLDOWN_SECONDS=30
# 이 횟수만큼 연속으로 코드 검증에 실패하면 해당 IP를 영구 차단한다.
MONITOR_AUTH_MAX_ATTEMPTS=3
# RFC1918/루프백/링크로컬 외에 "내부 IP"로 추가 인정할 CIDR (쉼표 구분, 선택).
# 예: Tailscale을 쓴다면 100.64.0.0/10
MONITOR_TRUSTED_CIDRS=
