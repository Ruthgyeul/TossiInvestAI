[Unit]
Description=Bin Monitor (kiosk dashboard)
After=network.target redis.service

[Service]
WorkingDirectory=/home/ruthgyeul/TossInvestAI/monitor
ExecStart=/usr/bin/node server.js
Restart=always
RestartSec=5
Environment=NODE_ENV=production
Environment=TZ=Asia/Seoul
# 외부에 노출되는 웹 프로세스를 root로 돌리지 않는다 + 최소 권한 하드닝.
User=ruthgyeul
Group=ruthgyeul
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full

[Install]
WantedBy=multi-user.target
